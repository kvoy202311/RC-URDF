<mujoco model="RCV8">
  <compiler angle="radian" meshdir="/home/kang/Desktop/RC_blind_terrain/legged_gym/resources/robots/RCV8/meshes/"/>

  <asset>
    <mesh name="base_link" content_type="model/stl" file="base_link.STL"/>
    <mesh name="FL" content_type="model/stl" file="FL.STL"/>
    <mesh name="FL_thigh" content_type="model/stl" file="FL_thigh.STL"/>
    <mesh name="FL_calf" content_type="model/stl" file="FL_calf.STL"/>
    <mesh name="FL_foot" content_type="model/stl" file="FL_foot.STL"/>
    <mesh name="FR" content_type="model/stl" file="FR.STL"/>
    <mesh name="FR_thigh" content_type="model/stl" file="FR_thigh.STL"/>
    <mesh name="FR_calf" content_type="model/stl" file="FR_calf.STL"/>
    <mesh name="FR_foot" content_type="model/stl" file="FR_foot.STL"/>
    <mesh name="RL" content_type="model/stl" file="RL.STL"/>
    <mesh name="RL_thigh" content_type="model/stl" file="RL_thigh.STL"/>
    <mesh name="RL_calf" content_type="model/stl" file="RL_calf.STL"/>
    <mesh name="RL_foot" content_type="model/stl" file="RL_foot.STL"/>
    <mesh name="RR" content_type="model/stl" file="RR.STL"/>
    <mesh name="RR_thigh" content_type="model/stl" file="RR_thigh.STL"/>
    <mesh name="RR_calf" content_type="model/stl" file="RR_calf.STL"/>
    <mesh name="RR_foot" content_type="model/stl" file="RR_foot.STL"/>
  </asset>

  <worldbody>
    <!--
      把机器人根部改成真正的 floating base。
      原始 XML 里 worldbody 下直接放了 base_link 几何和四条腿，这会让机器人天然固定在世界坐标系中，
      表现出来就是“机身像被固定在半空中，腿在下面摆动”。

      这里新增一个名为 base_link 的根 body，并把原先 worldbody 下的整台机器人内容整体收进来：
      1. body pos="0 0 0.52"：给机器人一个标准站立初始高度，使默认足端大致落在 z=0 地面附近。
      2. freejoint：给基座 6 自由度，让它成为真正的浮动基座，而不是世界固定体。
      3. 原来属于机器人本体的 base_link 几何和四条腿 body 全部保留，只是层级整体下移到这个根 body 内。
    -->
    <body name="base_link" pos="0 0 0.52">
      <!-- freejoint 让基座不再固定在世界坐标系中。 -->
      <freejoint/>
      <!--
        在 base_link 原点放置 IMU site。
        你说 IMU 与 base_link 坐标点重合，因此这里直接把 imu_site 放在根 body 的局部原点 pos="0 0 0"。
        这样读取到的 IMU 量就是以 base_link 原点为参考的机身传感信息。
      -->
      <site name="imu_site" pos="0 0 0" size="0.01" rgba="1 0 0 0.3"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="base_link"/>
          <geom size="0.17 0.1 0.0799" pos="0 0 0.0429" type="box" rgba="1 1 1 1"/>
          <body name="FL" pos="0.23285 0.0625 0.05425">
            <inertial pos="-0.0053276 -0.01473 -5.6068e-05" quat="0.707138 -0.0103477 -0.010502 0.706922" mass="0.75" diaginertia="0.00023468 0.000132891 0.000120589"/>
            <joint name="FL_hip_joint" pos="0 0 0" axis="1 0 0" range="-1.05 1.05" actuatorfrcrange="-23.7 23.7"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="FL"/>
            <body name="FL_thigh" pos="0 0.0904 0">
              <inertial pos="-0.0010734 -0.023217 -0.035481" quat="0.708144 0.0289938 0.0292909 0.704864" mass="0.85" diaginertia="0.0016592 0.00146522 0.000252001"/>
              <joint name="FL_thigh_joint" pos="0 0 0" axis="0 1 0" range="-1.57 3.49" actuatorfrcrange="-23.7 23.7"/>
              <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="FL_thigh"/>
              <geom size="0.045 0.025" pos="-0.003 -0.008 -0.002" quat="0.707107 0.707107 0 0" type="cylinder" rgba="1 1 1 1"/>
              <geom size="0.0205 0.081" pos="-0.022 0 -0.14" type="cylinder" rgba="1 1 1 1"/>
              <body name="FL_calf" pos="0 0 -0.26">
                <inertial pos="-0.0325828 -0.00695299 -0.17408" quat="0.629053 0.174423 0.208627 0.728247" mass="0.15" diaginertia="0.0017187 0.00144385 0.000286738"/>
                <joint name="FL_calf_joint" pos="0 0 0" axis="0 1 0" range="-2.72 -0.84" actuatorfrcrange="-23.7 23.7"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="FL_calf"/>
                <geom size="0.0125 0.125" pos="0.0155 0 -0.125" type="cylinder" rgba="1 1 1 1"/>
                <geom pos="-0.014048 0 -0.29437" quat="1 0 0 0" type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.79216 0.81961 0.93333 1" mesh="FL_foot"/>
                <geom size="0.0202" pos="-0.009748 0.0002 -0.28937" rgba="0.79216 0.81961 0.93333 1"/>
                <geom size="0.0135 0.01 0.0075" pos="0.006452 0.0002 -0.25937" type="box" rgba="0.79216 0.81961 0.93333 1"/>
              </body>
            </body>
          </body>
          <body name="FR" pos="0.23285 -0.0625 0.05425">
            <inertial pos="-0.0053276 0.01473 5.6068e-05" quat="0.706922 0.010502 0.0103477 0.707138" mass="0.75" diaginertia="0.00023468 0.000132891 0.000120589"/>
            <joint name="FR_hip_joint" pos="0 0 0" axis="1 0 0" range="-1.05 1.05" actuatorfrcrange="-23.7 23.7"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="FR"/>
            <body name="FR_thigh" pos="0 -0.0904 0">
              <inertial pos="-0.00090065 0.023659 -0.034449" quat="0.704866 0.0292758 0.0290018 0.708142" mass="0.85" diaginertia="0.001659 0.00146382 0.000250674"/>
              <joint name="FR_thigh_joint" pos="0 0 0" axis="0 1 0" range="-1.57 3.49" actuatorfrcrange="-23.7 23.7"/>
              <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="FR_thigh"/>
              <geom size="0.045 0.025" pos="-0.003 0.008 -0.002" quat="0.707107 0.707107 0 0" type="cylinder" rgba="1 1 1 1"/>
              <geom size="0.0205 0.081" pos="-0.022 0 -0.14" type="cylinder" rgba="1 1 1 1"/>
              <body name="FR_calf" pos="0 0 -0.26">
                <inertial pos="-0.0327061 -0.00240925 -0.174271" quat="0.663564 0.184188 0.195942 0.698115" mass="0.15" diaginertia="0.00171405 0.00144254 0.000282998"/>
                <joint name="FR_calf_joint" pos="0 0 0" axis="0 1 0" range="-2.72 -0.84" actuatorfrcrange="-23.7 23.7"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="FR_calf"/>
                <geom size="0.0125 0.125" pos="0.0155 0 -0.125" type="cylinder" rgba="1 1 1 1"/>
                <geom pos="-0.014048 0 -0.29437" quat="1 0 0 0" type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.79216 0.81961 0.93333 1" mesh="FR_foot"/>
                <geom size="0.0202" pos="-0.009748 -0.0002 -0.28937" rgba="0.79216 0.81961 0.93333 1"/>
                <geom size="0.0135 0.01 0.0075" pos="0.006452 -0.0002 -0.25937" type="box" rgba="0.79216 0.81961 0.93333 1"/>
              </body>
            </body>
          </body>
          <body name="RL" pos="-0.23285 0.0625 0.05425">
            <inertial pos="0.0053278 -0.01473 5.5449e-05" quat="0.706922 -0.010492 -0.0103376 0.707138" mass="0.75" diaginertia="0.00023468 0.000132891 0.000120589"/>
            <joint name="RL_hip_joint" pos="0 0 0" axis="1 0 0" range="-1.05 1.05" actuatorfrcrange="-23.7 23.7"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="RL"/>
            <body name="RL_thigh" pos="0 0.0904 0">
              <inertial pos="-0.0010734 -0.023217 -0.035481" quat="0.708144 0.0289938 0.0292909 0.704864" mass="0.85" diaginertia="0.0016592 0.00146522 0.000252001"/>
              <joint name="RL_thigh_joint" pos="0 0 0" axis="0 1 0" range="-0.52 4.54" actuatorfrcrange="-23.7 23.7"/>
              <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="RL_thigh"/>
              <geom size="0.045 0.025" pos="-0.003 -0.008 -0.002" quat="0.707107 0.707107 0 0" type="cylinder" rgba="1 1 1 1"/>
              <geom size="0.0205 0.081" pos="-0.022 0 -0.14" type="cylinder" rgba="1 1 1 1"/>
              <body name="RL_calf" pos="0 0 -0.26">
                <inertial pos="-0.0325834 -0.0069531 -0.174081" quat="0.629052 0.174424 0.208629 0.728247" mass="0.15" diaginertia="0.00171874 0.0014439 0.000286736"/>
                <joint name="RL_calf_joint" pos="0 0 0" axis="0 1 0" range="-2.72 -0.84" actuatorfrcrange="-23.7 23.7"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="RL_calf"/>
                <geom size="0.0125 0.125" pos="0.0155 0 -0.125" type="cylinder" rgba="1 1 1 1"/>
                <geom pos="-0.0140482 0 -0.294374" quat="1 0 0 0" type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.79216 0.81961 0.93333 1" mesh="RL_foot"/>
                <geom size="0.0206" pos="-0.00974823 0.0002 -0.289374" rgba="0.79216 0.81961 0.93333 1"/>
                <geom size="0.0135 0.01 0.0075" pos="0.00645177 0.0002 -0.259374" type="box" rgba="0.79216 0.81961 0.93333 1"/>
              </body>
            </body>
          </body>
          <body name="RR" pos="-0.23285 -0.0625 0.05425">
            <inertial pos="0.0053276 0.01473 -5.6068e-05" quat="0.707138 0.0103477 0.010502 0.706922" mass="0.75" diaginertia="0.00023468 0.000132891 0.000120589"/>
            <joint name="RR_hip_joint" pos="0 0 0" axis="1 0 0" range="-1.05 1.05" actuatorfrcrange="-23.7 23.7"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="RR"/>
            <body name="RR_thigh" pos="0 -0.0904 0">
              <inertial pos="-0.0009009 0.023659 -0.034449" quat="0.704866 0.0292758 0.0290018 0.708142" mass="0.85" diaginertia="0.001659 0.00146382 0.000250674"/>
              <joint name="RR_thigh_joint" pos="0 0 0" axis="0 1 0" range="-0.52 4.54" actuatorfrcrange="-23.7 23.7"/>
              <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="RR_thigh"/>
              <geom size="0.045 0.025" pos="-0.003 0.008 -0.002" quat="0.707107 0.707107 0 0" type="cylinder" rgba="1 1 1 1"/>
              <geom size="0.0205 0.081" pos="-0.022 0 -0.14" type="cylinder" rgba="1 1 1 1"/>
