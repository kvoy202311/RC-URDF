                <geom pos="-0.014048 0 -0.29437" quat="1 0 0 0" type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.79216 0.81961 0.93333 1" mesh="RR_foot"/>
                <geom size="0.02" pos="-0.009748 -0.0002 -0.28937" rgba="0.79216 0.81961 0.93333 1"/>
