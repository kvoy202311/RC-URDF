                <inertial pos="-0.0326884 -0.00241041 -0.174279" quat="0.663577 0.184084 0.195843 0.698158" mass="0.15" diaginertia="0.0017138 0.00144247 0.000282812"/>
                <joint name="RR_calf_joint" pos="0 0 0" axis="0 1 0" range="-2.72 -0.84" actuatorfrcrange="-23.7 23.7"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="RR_calf"/>
